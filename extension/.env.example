# Backend URL the extension talks to. Baked in at build time.
#
# Local dev (default):
PLASMO_PUBLIC_API_URL=http://localhost:3000
#
# Hosted (auth-gated):
# PLASMO_PUBLIC_API_URL=https://magio.deepaksilaych.me
#
# Self-host with your own dashboard:
# PLASMO_PUBLIC_API_URL=https://your-magio.example.com
